<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minha Jornada Gamedev</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <style>
        /* Linha do tempo limpa e integrada ao tema escuro */
        .timeline { position: relative; max-width: 800px; margin: 2rem auto; padding: 1rem; }
        
        /* LINHA ROXA REMOVIDA POR COMPLETO DE TODOS OS SELETORES */
        .timeline::after { display: none !important; content: none !important; }
        
        .timeline-item { padding: 10px 0px 10px 40px; position: relative; background-color: inherit; width: 100%; box-sizing: border-box; }
        
        /* Marcador de Check Verde Estilizado */
        .timeline-item::after { 
            content: '✓'; 
            position: absolute; 
            width: 22px; 
            height: 22px; 
            right: auto; 
            background-color: #121214; 
            border: 2px solid #04d361; 
            top: 22px; 
            left: 5px; 
            border-radius: 50%; 
            z-index: 1; 
            color: #04d361;
            font-size: 13px;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .timeline-card { padding: 1.5rem; background: #1a1a1e; border: 1px solid #323238; position: relative; border-radius: 8px; }
        .badge-versao { background: #04d361; color: #000; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.75rem; font-weight: bold; margin-right: 0.5rem; }
        .timeline-card img { max-width: 100%; border-radius: 4px; margin-top: 1rem; display: block; }

        /* Estilização Premium do Rodapé com Cores Oficiais das Redes */
        .social-link { text-decoration: none; font-size: 1.8rem; color: #8d8d99; transition: all 0.3s ease; display: inline-block; }
        .social-link.instagram:hover { color: #e1306c; transform: scale(1.2); }
        .social-link.youtube:hover { color: #ff0000; transform: scale(1.2); }
        .social-link.twitch:hover { color: #9146ff; transform: scale(1.2); }
        .social-link.twitter:hover { color: #ffffff; transform: scale(1.2); }
    </style>
</head>
<body>

    <nav id="sidebar" class="sidebar-fechada">
        <button id="btn-menu">☰</button>
        <ul class="menu-links">
            <li><a href="/">🏠 <span>Início</span></a></li>
            <li><a href="/galeria">🖼️ <span>Galeria</span></a></li>
            <li><a href="/apoie">🤝 <span>Apoie</span></a></li>
            <li><a href="/comunidade">💬 <span>Comunidade</span></a></li>
            <li><a href="/admin">⚙️ <span>Admin</span></a></li>
        </ul>
    </nav>

    <div id="conteudo-principal" style="display: flex; flex-direction: column; min-height: 100vh;">
        
        <div style="flex: 1;">
            <header style="text-align: center; margin-bottom: 2rem;">
                <h1>🎮 Minha Jornada Gamedev</h1>
                <p>Acompanhe os bastidores da criação do meu jogo do zero.</p>
            </header>

            <section class="timeline">
                <% if (posts && posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                        <div class="timeline-item">
                            <div class="timeline-card">
                                <div style="display: flex; align-items: center; margin-bottom: 0.5rem;">
                                    <span class="badge-versao"><%= post.versao %></span>
                                    <span style="color: #8d8d99; font-size: 0.85rem;"><%= post.data %></span>
                                </div>
                                <h2 style="color: #fff; margin: 0.5rem 0;"><%= post.titulo %></h2>
                                <p style="line-height: 1.6; color: #c4c4cc;"><%= post.conteudo %></p>
                                
                                <% if (post.imagem) { %>
                                    <img src="<%= post.imagem %>" alt="Print do desenvolvimento">
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="text-align: center; color: #8d8d99; margin-top: 3rem;">Nenhuma atualização foi postada na linha do tempo ainda.</p>
                <% } %>
            </section>
        </div>

       <footer style="width: 100%; max-width: 1200px; margin: 4rem auto 2rem auto; padding-top: 2rem; border-top: 1px solid #323238; text-align: center; color: #8d8d99; font-size: 0.85rem; clear: both;">
    <p style="margin-bottom: 1.5rem;">Siga as redes oficiais do jogo para não perder nenhuma novidade!</p>
    
    <div style="display: flex; justify-content: center; gap: 3rem;">
        <a href="https://instagram.com/SEU_PERFIL" target="_blank" title="Instagram" class="social-link instagram">
            <i class="fa-brands fa-instagram"></i>
        </a>
        <a href="https://youtube.com/SEU_CANAL" target="_blank" title="YouTube" class="social-link youtube">
            <i class="fa-brands fa-youtube"></i>
        </a>
        <a href="https://twitch.tv/SEU_CANAL" target="_blank" title="Twitch" class="social-link twitch">
            <i class="fa-brands fa-twitch"></i>
        </a>
        <a href="https://x.com/SEU_PERFIL" target="_blank" title="Twitter / X" class="social-link twitter">
            <i class="fa-brands fa-x-twitter"></i>
        </a>
        <a href="https://discord.gg/SEU_SERVIDOR" target="_blank" title="Discord" class="social-link discord">
            <i class="fa-brands fa-discord"></i>
        </a>
    </div>
    
    <p style="margin-top: 1.5rem; font-size: 0.75rem; color: #41414c;">© 2026 Devlog Gamedev Santhi . Todos os direitos reservados.</p>
</footer>

    </div>

    <script>
        const sidebar = document.getElementById('sidebar');
        const btnMenu = document.getElementById('btn-menu');
        btnMenu.addEventListener('click', () => {
            sidebar.classList.toggle('sidebar-fechada');
        });
    </script>
</body>
</html>